# Application Server
PORT=8080
HOST=0.0.0.0

# Dataset Profile
# Options: SMALL (~10k rows), MEDIUM (~250k rows), LARGE (1M+ rows)
DATASET_PROFILE=SMALL

# AI Engine Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Settings
GCP_PROJECT_ID=your_gcp_project_id_here
BIGQUERY_DATASET=pulseops_ai
# Storage path (optional, local file overrides)
TELEMETRY_CSV_PATH=datasets/equipment_telemetry.csv
